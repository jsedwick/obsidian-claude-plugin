{
  "description": "Obsidian vault integration hooks for session lifecycle, content validation, and file tracking",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-end.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/user-prompt-vault-search.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__obsidian-context-manager__create_topic_page|mcp__obsidian-context-manager__create_decision",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pretooluse-content-type-check.sh"
          }
        ]
      },
      {
        "matcher": "mcp__obsidian-context-manager__close_session",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pretooluse-prevent-direct-close-session.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pretooluse-enforce-tracked-edits.sh"
          }
        ]
      }
    ]
  }
}
